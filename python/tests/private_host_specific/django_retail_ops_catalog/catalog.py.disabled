def test_django_catalog_uses_view_get_serializer_class_for_get_response_schema():
    class ListSerializer(serializers.Serializer):
        list_id = serializers.UUIDField()

    class WriteSerializer(serializers.Serializer):
        write_id = serializers.UUIDField()

    class ListCreateView:
        serializer_class = WriteSerializer
        query_serializer_class = None
        permission_classes = ()

        def get(self):
            pass

        def post(self):
            pass

        def get_serializer_class(self):
            if self.request.method == "GET":
                return ListSerializer
            return self.serializer_class

    contract = _build_contract(
        path="v1/things/",
        url_name="thing-list",
        view_class=ListCreateView,
        converters={},
    )

    assert (
        contract.response_schema_source.endswith(".ListSerializer"),
        {item.path for item in contract.response_fields},
    ) == (True, {"list_id"})


def test_django_catalog_does_not_infer_identity_from_resource_name_suffix():
    class PlainSerializer(serializers.Serializer):
        sale_id = serializers.UUIDField()
        amount = serializers.DecimalField(max_digits=10, decimal_places=2)

    class PlainView:
        serializer_class = PlainSerializer
        query_serializer_class = None
        permission_classes = ()

        def get(self):
            pass

    contract = _build_contract(
        path="v1/sales/",
        url_name="sale-list",
        view_class=PlainView,
        converters={},
    )

    sale_id = next(item for item in contract.response_fields if item.path == "sale_id")
    amount = next(item for item in contract.response_fields if item.path == "amount")

    assert (sale_id.identity, amount.identity) == ({}, {})


def test_django_catalog_marks_identity_from_serializer_model_primary_key():
    class RecordPk:
        name = "record_id"
        attname = "record_id"
        primary_key = True
        remote_field = None

    class RecordMeta:
        pk = RecordPk()
        object_name = "InventoryRecord"
        model_name = "inventory_record"
        fields = (pk,)

        def get_field(self, name):
            if name == "record_id":
                return self.pk
            raise LookupError(name)

    class InventoryRecord:
        _meta = RecordMeta()

    class PlainSerializer(serializers.Serializer):
        record_id = serializers.UUIDField()
        amount = serializers.DecimalField(max_digits=10, decimal_places=2)

        class Meta:
            model = InventoryRecord

    class PlainView:
        serializer_class = PlainSerializer
        query_serializer_class = None
        permission_classes = ()

        def get(self):
            pass

    contract = _build_contract(
        path="v1/records/",
        url_name="record-list",
        view_class=PlainView,
        converters={},
    )

    record_id = next(
        item for item in contract.response_fields if item.path == "record_id"
    )
    amount = next(item for item in contract.response_fields if item.path == "amount")

    assert (record_id.identity, amount.identity) == (
        {
            "entityRef": "inventory_record",
            "idField": "record_id",
            "primaryKey": True,
        },
        {},
    )


def test_django_catalog_uses_declared_source_for_identity_resolution():
    class RecordPk:
        name = "record_id"
        attname = "record_id"
        primary_key = True
        remote_field = None

    class ExternalReferenceField:
        name = "external_reference"
        attname = "external_reference"
        primary_key = False
        remote_field = None

    class RecordMeta:
        pk = RecordPk()
        object_name = "InventoryRecord"
        model_name = "inventory_record"
        fields = (pk, ExternalReferenceField())

        def get_field(self, name):
            for field in self.fields:
                if field.name == name:
                    return field
            raise LookupError(name)

    class InventoryRecord:
        _meta = RecordMeta()

    class PlainSerializer(serializers.Serializer):
        record_id = serializers.UUIDField(source="external_reference")

        class Meta:
            model = InventoryRecord

    class PlainView:
        serializer_class = PlainSerializer
        query_serializer_class = None
        permission_classes = ()

        def get(self):
            pass

    contract = _build_contract(
        path="v1/records/",
        url_name="record-list",
        view_class=PlainView,
        converters={},
    )

    record_id = next(
        item for item in contract.response_fields if item.path == "record_id"
    )

    assert record_id.identity == {}


def test_django_catalog_marks_identity_from_get_queryset_model_primary_key():
    class RecordPk:
        name = "record_id"
        attname = "record_id"
        primary_key = True
        remote_field = None

    class RecordMeta:
        pk = RecordPk()
        object_name = "InventoryRecord"
        model_name = "inventory_record"
        fields = (pk,)

        def get_field(self, name):
            if name == "record_id":
                return self.pk
            raise LookupError(name)

    class InventoryRecord:
        _meta = RecordMeta()

    class QuerySet:
        model = InventoryRecord

    class PlainSerializer(serializers.Serializer):
        record_id = serializers.UUIDField()
        amount = serializers.DecimalField(max_digits=10, decimal_places=2)

    class PlainView:
        serializer_class = PlainSerializer
        query_serializer_class = None
        permission_classes = ()

        def get_queryset(self):
            return QuerySet()

        def get(self):
            pass

    contract = _build_contract(
        path="v1/records/",
        url_name="record-list",
        view_class=PlainView,
        converters={},
    )

    record_id = next(
        item for item in contract.response_fields if item.path == "record_id"
    )
    amount = next(item for item in contract.response_fields if item.path == "amount")

    assert (record_id.identity, amount.identity) == (
        {
            "entityRef": "inventory_record",
            "idField": "record_id",
            "primaryKey": True,
        },
        {},
    )


