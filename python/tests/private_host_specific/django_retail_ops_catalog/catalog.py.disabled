import pytest
from django.urls import path
from rest_framework import serializers, viewsets

from fervis.host_api.adapters.django.catalog import (
    _build_contract,
    get_endpoint_contract as _get_endpoint_contract,
    get_endpoint_contracts as _get_endpoint_contracts,
)
from fervis.host_api.adapters.django import catalog as django_catalog
from fervis.host_api.adapters.django.schema_introspection import (
    conditional_response_roots_from_serializer,
    response_fields_from_serializer,
)
from fervis.project.integration import (
    DjangoAppSource,
    FervisConfig,
    HostConfig,
    ModelConfig,
    ProviderConfig,
    RuntimeRoutes,
)
from fervis.project.source_scope import (
    DjangoSourceScope,
    django_source_scopes,
)

_DEFAULT_SOURCES = (
    DjangoSourceScope(
        name="commerce",
        app_modules=("apps.retail_ops", "apps.brands"),
        path_prefixes=("/v1/",),
    ),
)


def get_endpoint_contract(
    endpoint_name: str,
    *,
    sources: tuple[DjangoSourceScope, ...] = _DEFAULT_SOURCES,
):
    return _get_endpoint_contract(
        endpoint_name,
        sources=sources,
    )


def get_endpoint_contracts(
    *,
    sources: tuple[DjangoSourceScope, ...] = _DEFAULT_SOURCES,
):
    return _get_endpoint_contracts(
        sources=sources,
    )


def test_django_catalog_requires_explicit_source_scope() -> None:
    with pytest.raises(TypeError):
        django_catalog.get_endpoint_contracts()


def test_django_source_scopes_preserve_source_boundaries() -> None:
    config = FervisConfig(
        host=HostConfig(),
        routes=RuntimeRoutes(prefix="/fervis/"),
        model=ModelConfig(
            default_provider="openai",
            default_model_key="gpt-5.4-mini",
            providers=[
                ProviderConfig(
                    name="openai",
                    allowed_model_keys=["gpt-5.4-mini"],
                )
            ],
        ),
        sources=(
            DjangoAppSource(
                name="sales",
                app_modules=("apps.sales",),
                path_prefixes=("/v1/sales/",),
            ),
            DjangoAppSource(
                name="inventory",
                app_modules=("apps.inventory",),
                path_prefixes=("/v1/inventory/",),
            ),
        ),
    )

    assert django_source_scopes(config) == (
        DjangoSourceScope(
            name="sales",
            app_modules=("apps.sales",),
            path_prefixes=("/v1/sales/",),
        ),
        DjangoSourceScope(
            name="inventory",
            app_modules=("apps.inventory",),
            path_prefixes=("/v1/inventory/",),
        ),
    )


@pytest.mark.django_db
def test_contract_registry_includes_shift_records_query_and_response_schema(
    fervis_foundation_reset,
):
    contract = get_endpoint_contract("list_shift_record_list")

    assert {
        "path_template": contract.path_template,
        "has_query_params": {
            "start_date",
            "end_date",
            "location_id",
            "staff_id",
            "status",
            "is_validated",
            "limit",
            "offset",
        }.issubset({item.name for item in contract.query_params}),
        "has_response_fields": {"is_late", "staff_name"}.issubset(
            set(contract.response_schema)
        ),
        "query_schema_source": contract.query_schema_source != "missing",
        "response_schema_source": contract.response_schema_source != "missing",
    } == {
        "path_template": "/v1/shift-records/",
        "has_query_params": True,
        "has_response_fields": True,
        "query_schema_source": True,
        "response_schema_source": True,
    }


@pytest.mark.django_db
def test_contract_registry_includes_location_shift_records_resource_endpoint(
    fervis_foundation_reset,
):
    contract = get_endpoint_contract("get_location_shift_records")

    assert {
        "path_template": contract.path_template,
        "path_params": [item.name for item in contract.path_params],
        "has_query_params": {"start_date", "end_date", "staff_id", "status"}.issubset(
            {item.name for item in contract.query_params}
        ),
        "has_response_fields": {"staff_name", "location_id"}.issubset(
            set(contract.response_schema)
        ),
    } == {
        "path_template": "/v1/locations/{location_id}/shift-records/",
        "path_params": ["location_id"],
        "has_query_params": True,
        "has_response_fields": True,
    }


@pytest.mark.django_db
def test_contract_registry_includes_shift_compensation_filter_params(
    fervis_foundation_reset,
):
    contract = get_endpoint_contract("list_shift_compensation_list")

    query_params = {item.name: item for item in contract.query_params}
    catalog_endpoint = contract.catalog_endpoint
    assert catalog_endpoint is not None
    assert {
        "has_params": {"start_date", "end_date", "location_id"}.issubset(
            query_params
        ),
        "start_date_type": query_params["start_date"].type,
        "end_date_type": query_params["end_date"].type,
        "framework_kind": catalog_endpoint.framework_kind,
        "namespace_kind": catalog_endpoint.source_namespace_kind,
        "namespace_path": catalog_endpoint.source_namespace_path,
        "handler_ref_includes_module": "apps.retail_ops" in catalog_endpoint.handler_ref,
    } == {
        "has_params": True,
        "start_date_type": "date",
        "end_date_type": "date",
        "framework_kind": "django_drf",
        "namespace_kind": "django_app",
        "namespace_path": ("retail_ops",),
        "handler_ref_includes_module": True,
    }


@pytest.mark.django_db
def test_contract_registry_marks_nested_fk_response_fields_as_entity_identities(
    fervis_foundation_reset,
):
    contract = get_endpoint_contract("list_shift_compensation_list")

    fields = {item.name: item for item in contract.response_fields}

    assert {
        name: fields[name].identity
        for name in ("staff_id", "location_id", "staff_name", "location_name")
    } == {
        "staff_id": {
            "entityRef": "staff",
            "idField": "staff_id",
            "primaryKey": True,
        },
        "location_id": {
            "entityRef": "location",
            "idField": "location_id",
            "primaryKey": True,
        },
        "staff_name": {},
        "location_name": {},
    }


