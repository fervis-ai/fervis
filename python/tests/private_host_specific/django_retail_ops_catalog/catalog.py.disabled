@pytest.mark.django_db
def test_contract_registry_keeps_conditional_items_when_endpoint_exposes_expansion_param(
    fervis_foundation_reset,
):
    contract = get_endpoint_contract("list_sale_list")

    assert contract is not None
    query_params = {item.name for item in contract.query_params}
    response_paths = {item.path for item in contract.response_fields}
    item_field = next(
        item
        for item in contract.response_fields
        if item.path == "items.snapshot_shade_name"
    )

    assert (
        "include_items" in query_params,
        "items.snapshot_shade_name" in response_paths,
        item_field.to_public_dict()["requires"],
    ) == (
        True,
        True,
        {"queryParam": "include_items", "value": True},
    )


def test_conditional_response_roots_come_from_explicit_serializer_metadata():
    class ContractMetadataSerializer(serializers.Serializer):
        fervis_conditional_response_roots = ("items",)

        items = serializers.ListField()

    assert conditional_response_roots_from_serializer(ContractMetadataSerializer) == (
        "items",
    )


def test_serializer_introspection_fails_fast_on_initialization_errors():
    class BrokenSerializer(serializers.Serializer):
        def __init__(self, *args, **kwargs):
            raise RuntimeError("requires context")

    with pytest.raises(ValueError, match="Could not instantiate DRF serializer"):
        response_fields_from_serializer(BrokenSerializer)


def test_serializer_method_field_uses_return_annotation_for_response_type():
    class MethodTypeSerializer(serializers.Serializer):
        is_open = serializers.SerializerMethodField()

        def get_is_open(self, obj) -> bool:
            return True

    fields = {
        field.name: field
        for field in response_fields_from_serializer(MethodTypeSerializer)
    }

    assert fields["is_open"].type == "boolean"


