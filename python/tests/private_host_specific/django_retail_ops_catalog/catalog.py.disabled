def test_django_catalog_does_not_treat_detail_view_as_collection_for_paginate_method():
    class DetailView:
        serializer_class = None
        query_serializer_class = None
        permission_classes = ()

        def get(self):
            pass

        def paginate_queryset(self, queryset):
            return queryset

    contract = _build_contract(
        path="v1/widgets/<id>/",
        url_name="widget-detail",
        view_class=DetailView,
        converters={},
    )

    assert (contract.paginated, contract.is_detail_endpoint()) == (False, True)


def test_django_catalog_includes_drf_router_viewset_get_actions():
    class WidgetSerializer(serializers.Serializer):
        id = serializers.CharField()

    class WidgetViewSet(viewsets.ViewSet):
        serializer_class = WidgetSerializer
        permission_classes = ()

        def list(self, request):
            raise AssertionError("catalog introspection must not execute the view")

    contracts = []

    django_catalog._walk_patterns(
        [
            path(
                "widgets/",
                WidgetViewSet.as_view({"get": "list"}),
                name="widget-list",
            )
        ],
        "",
        contracts,
        app_modules=(__name__,),
        path_prefixes=("/",),
    )

    assert [contract.endpoint_name for contract in contracts] == ["list_widget_list"]


@pytest.mark.django_db
def test_response_field_introspection_does_not_evaluate_relation_choices():
    class ExplodingQueryset:
        model = object

        def all(self):
            return self

        def __iter__(self):
            raise AssertionError("relation queryset was evaluated")

        def __bool__(self):
            return True

    class RelationSerializer(serializers.Serializer):
        groups = serializers.PrimaryKeyRelatedField(
            queryset=ExplodingQueryset(),
            many=True,
        )

    fields = response_fields_from_serializer(RelationSerializer)

    assert [(field.path, field.choices) for field in fields] == [("groups", ())]


def test_django_catalog_uses_explicit_serializer_resource_names():
    class PlainSerializer(serializers.Serializer):
        fervis_resource_names = ("activity record",)

        record_id = serializers.UUIDField()

    class PlainView:
        serializer_class = PlainSerializer
        query_serializer_class = None
        permission_classes = ()

        def get(self):
            pass

    contract = _build_contract(
        path="v1/activity-records/",
        url_name="activity-record-list",
        view_class=PlainView,
        converters={},
    )

    assert "activity record" in contract.resource_names


@pytest.mark.django_db
def test_django_catalog_uses_endpoint_model_metadata_for_common_id_primary_keys(
    fervis_foundation_reset,
):
    contract = get_endpoint_contract("list_cron_job_list")
    id_field = next(field for field in contract.response_fields if field.path == "id")

    assert id_field.identity == {
        "entityRef": "cron_job_run",
        "idField": "id",
        "primaryKey": True,
    }


def test_django_catalog_does_not_infer_identity_from_global_field_name():
    class ExternalIdPk:
        name = "external_id"

    class ExternalThingMeta:
        pk = ExternalIdPk()
        object_name = "ExternalThing"
        model_name = "external_thing"

    class ExternalThing:
        _meta = ExternalThingMeta()

    class PlainSerializer(serializers.Serializer):
        external_id = serializers.UUIDField()

    class PlainView:
        serializer_class = PlainSerializer
        query_serializer_class = None
        permission_classes = ()

        def get(self):
            pass

    django_catalog.clear_endpoint_contract_cache()
    try:
        contract = _build_contract(
            path="v1/plain-records/",
            url_name="plain-record-list",
            view_class=PlainView,
            converters={},
        )
    finally:
        django_catalog.clear_endpoint_contract_cache()

    field = next(
        item for item in contract.response_fields if item.path == "external_id"
    )
    assert field.identity == {}
