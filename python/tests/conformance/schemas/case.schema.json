{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fervis.test/conformance/case.schema.json",
  "title": "Fervis conformance case",
  "$defs": {
    "portableAnswerProgramBase": {
      "type": "object",
      "required": ["schema_revision"],
      "properties": {
        "schema_revision": {"const": 1}
      },
      "not": {
        "anyOf": [
          {"required": ["fixture"]},
          {"required": ["scenario"]}
        ]
      }
    },
    "canonicalizeInput": {
      "allOf": [
        {"$ref": "#/$defs/portableAnswerProgramBase"},
        {
          "required": ["schema_revision", "programs"],
          "additionalProperties": false,
          "properties": {
            "schema_revision": {"const": 1},
            "programs": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "object"}
            },
            "binding_sets": {"type": "array"},
            "patches": {"type": "array"},
            "constants": {"type": "array"},
            "run_id": {"type": "string"}
          }
        }
      ]
    },
    "compileInput": {
      "allOf": [
        {"$ref": "#/$defs/portableAnswerProgramBase"},
        {
          "required": [
            "schema_revision",
            "program",
            "question_contract",
            "catalog",
            "bindings"
          ],
          "additionalProperties": false,
          "properties": {
            "schema_revision": {"const": 1},
            "program": {"type": "object"},
            "question_contract": {"type": "object"},
            "catalog": {"type": "object"},
            "bindings": {"type": "array"}
          }
        }
      ]
    },
    "decodeInput": {
      "allOf": [
        {"$ref": "#/$defs/portableAnswerProgramBase"},
        {
          "required": ["schema_revision", "program"],
          "additionalProperties": false,
          "properties": {
            "schema_revision": {"const": 1},
            "program": {"type": "object"}
          }
        }
      ]
    },
    "patchInput": {
      "allOf": [
        {"$ref": "#/$defs/portableAnswerProgramBase"},
        {
          "required": ["schema_revision", "parameters", "bindings"],
          "oneOf": [
            {"required": ["patch"]},
            {"required": ["attempts"]}
          ],
          "additionalProperties": false,
          "properties": {
            "schema_revision": {"const": 1},
            "parameters": {"type": "array"},
            "bindings": {"type": "array"},
            "patch": {"type": "object"},
            "attempts": {"type": "array"}
          }
        }
      ]
    },
    "capabilityInput": {
      "allOf": [
        {"$ref": "#/$defs/portableAnswerProgramBase"},
        {
          "required": [
            "schema_revision",
            "program",
            "bindings",
            "application"
          ],
          "additionalProperties": false,
          "properties": {
            "schema_revision": {"const": 1},
            "program": {"type": "object"},
            "bindings": {"type": "array"},
            "application": {"type": "object"}
          }
        }
      ]
    },
    "instantiateInput": {
      "allOf": [
        {"$ref": "#/$defs/portableAnswerProgramBase"},
        {
          "required": ["schema_revision", "attempts"],
          "additionalProperties": false,
          "properties": {
            "schema_revision": {"const": 1},
            "attempts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "program",
                  "bindings",
                  "catalog",
                  "environment"
                ],
                "additionalProperties": false,
                "properties": {
                  "id": {"type": "string"},
                  "program": {"type": "object"},
                  "bindings": {"type": "array"},
                  "catalog": {"type": "object"},
                  "environment": {"type": "object"},
                  "compatibility": {"type": "object"}
                }
              }
            }
          }
        }
      ]
    },
    "invokeInput": {
      "allOf": [
        {"$ref": "#/$defs/portableAnswerProgramBase"},
        {
          "required": [
            "schema_revision",
            "program",
            "catalog",
            "environment",
            "invocations"
          ],
          "additionalProperties": false,
          "properties": {
            "schema_revision": {"const": 1},
            "program": {"type": "object"},
            "catalog": {"type": "object"},
            "environment": {"type": "object"},
            "invocations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["id", "bindings", "evidence"],
                "additionalProperties": false,
                "properties": {
                  "id": {"type": "string"},
                  "bindings": {"type": "array"},
                  "evidence": {"type": "array"}
                }
              }
            }
          }
        }
      ]
    },
    "portableQuestionLifecycleInput": {
      "type": "object",
      "required": ["schema_revision", "operation"],
      "oneOf": [
        {"required": ["state", "command"]},
        {"required": ["attempts"]}
      ],
      "additionalProperties": false,
      "properties": {
        "schema_revision": {"const": 1},
        "operation": {"enum": ["rerun", "rerun_eligibility"]},
        "state": {"type": "object"},
        "command": {"type": "object"},
        "after_enqueue": {"type": "object"},
        "attempts": {"type": "array", "minItems": 1}
      }
    }
  },
  "type": "object",
  "required": ["id", "kind", "expect"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_]*$"
    },
    "description": {
      "type": "string"
    },
    "migrates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kind": {
      "enum": ["algorithm", "adapter"]
    },
    "algorithm": {
      "enum": [
        "answer_program.canonicalize",
        "answer_program.apply_capability",
        "answer_program.compile",
        "answer_program.decode",
        "answer_program.instantiate",
        "answer_program.invoke",
        "answer_program.patch",
        "business_time.resolve",
        "conversation_memory.card_projection",
        "conversation_memory.expand_activated",
        "conversation_resolution.parse",
        "conversation_resolution.overlay",
        "conversation_resolution.schema",
        "question_contract.parse",
        "question_contract.schema",
        "question_contract.schema_validate",
        "question_contract.prompt",
        "questions.projection",
        "questions.memory_projection",
        "query_enrichment.parse",
        "query_enrichment.schema",
        "query_enrichment.prompt",
        "read_eligibility.parse",
        "read_eligibility.schema_validate",
        "read_eligibility.prompt",
        "read_eligibility.cards",
        "read_eligibility.prepare_recall",
        "source_binding.bound_params",
        "source_binding.finite_choice_parse",
        "source_binding.fulfillment_support",
        "source_binding.metric_fit_parse",
        "source_binding.metric_fit_surface",
        "source_binding.parse",
        "source_binding.prompt_surface",
        "source_binding.row_predicates",
        "source_binding.row_predicate_parse",
        "source_binding.row_predicate_schema",
        "source_binding.review_scope",
        "source_binding.schema_surface",
        "execution.relation_engine",
        "execution.calendar_relation",
        "execution.endpoint_response",
        "execution.proof_graph",
        "execution.identity_set_binding",
        "lineage.explain",
        "lineage.input_lineage",
        "lookup.orchestration",
        "outcomes.classify",
        "plan_selection.prompt_surface",
        "catalog_selection.resolver_select",
        "catalog_selection.select",
        "relation_catalog.row_source_projection",
        "questions.lifecycle",
        "planning.fact_endpoint_requirements",
        "planning.fact_plan_schema",
        "planning.grouped_ranked_choices",
        "planning.relation_contract",
        "planning.value_contract",
        "planning.value_uses",
        "core.capabilities_from_schema",
        "grounding.contract",
        "memory.activate",
        "memory.build_artifact",
        "memory.lineage_memory_artifacts",
        "memory.lookup_projection",
        "memory.identity_projection",
        "memory.planner_contract",
        "memory.prior_answer_request",
        "memory.project_conversation",
        "memory.outcome_address",
        "memory.answer_addresses",
        "memory.available_values"
      ]
    },
    "adapter": {
      "enum": ["host_api.endpoint_contract_projection"]
    },
    "input": {
      "type": "object"
    },
    "expect": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        {
          "required": ["result_contains"]
        },
        {
          "required": ["result_equals"]
        },
        {
          "required": ["result_exact_fields"]
        }
      ],
      "properties": {
        "result_contains": {
          "type": "object"
        },
        "result_equals": {
          "type": "object"
        },
        "result_exact_fields": {
          "type": "object"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "algorithm"
          }
        }
      },
      "then": {
        "required": ["algorithm", "input"]
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "adapter"
          }
        }
      },
      "then": {
        "required": ["adapter", "input"]
      }
    },
    {
      "if": {"required": ["algorithm"], "properties": {"algorithm": {"const": "answer_program.canonicalize"}}},
      "then": {"properties": {"input": {"$ref": "#/$defs/canonicalizeInput"}}}
    },
    {
      "if": {"required": ["algorithm"], "properties": {"algorithm": {"const": "answer_program.compile"}}},
      "then": {"properties": {"input": {"$ref": "#/$defs/compileInput"}}}
    },
    {
      "if": {"required": ["algorithm"], "properties": {"algorithm": {"const": "answer_program.decode"}}},
      "then": {"properties": {"input": {"$ref": "#/$defs/decodeInput"}}}
    },
    {
      "if": {"required": ["algorithm"], "properties": {"algorithm": {"const": "answer_program.patch"}}},
      "then": {"properties": {"input": {"$ref": "#/$defs/patchInput"}}}
    },
    {
      "if": {"required": ["algorithm"], "properties": {"algorithm": {"const": "answer_program.apply_capability"}}},
      "then": {"properties": {"input": {"$ref": "#/$defs/capabilityInput"}}}
    },
    {
      "if": {"required": ["algorithm"], "properties": {"algorithm": {"const": "answer_program.instantiate"}}},
      "then": {"properties": {"input": {"$ref": "#/$defs/instantiateInput"}}}
    },
    {
      "if": {"required": ["algorithm"], "properties": {"algorithm": {"const": "answer_program.invoke"}}},
      "then": {"properties": {"input": {"$ref": "#/$defs/invokeInput"}}}
    },
    {
      "if": {
        "required": ["algorithm", "input"],
        "properties": {
          "algorithm": {"const": "questions.lifecycle"},
          "input": {
            "required": ["schema_revision"],
            "properties": {"schema_revision": {"const": 1}}
          }
        }
      },
      "then": {
        "properties": {
          "input": {"$ref": "#/$defs/portableQuestionLifecycleInput"}
        }
      }
    }
  ]
}
